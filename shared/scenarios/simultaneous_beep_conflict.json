{
  "name": "simultaneous_beep_conflict",
  "baseURL": "https://beepbeep.to",
  "participants": {
    "a": {
      "handle": "@avery",
      "deviceId": "sim-scenario-avery"
    },
    "b": {
      "handle": "@blake",
      "deviceId": "sim-scenario-blake"
    }
  },
  "steps": [
    {
      "description": "both Friends open each other",
      "actions": [
        { "actor": "a", "type": "openFriend", "friend": "b" },
        { "actor": "b", "type": "openFriend", "friend": "a" }
      ]
    },
    {
      "description": "both peers attempt to connect in the same step",
      "actions": [
        { "actor": "a", "type": "connect" },
        { "actor": "b", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "incomingBeep", "isJoined": false },
        "b": { "selectedHandle": "@avery", "phase": "incomingBeep", "isJoined": false }
      }
    },
    {
      "description": "sender resolves the conflict into a ready Conversation",
      "actions": [
        { "actor": "a", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "waitingForPeer", "isJoined": true },
        "b": { "selectedHandle": "@avery", "phase": "friendReady", "isJoined": false }
      }
    },
    {
      "description": "second peer joins and both sides become ready",
      "actions": [
        { "actor": "b", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "ready", "isJoined": true, "canTransmitNow": true },
        "b": { "selectedHandle": "@avery", "phase": "ready", "isJoined": true, "canTransmitNow": true }
      }
    },
    {
      "description": "refreshing request state after convergence does not resurface either Beep",
      "actions": [
        { "actor": "a", "type": "refreshBeeps" },
        { "actor": "b", "type": "refreshBeeps" },
        { "actor": "a", "type": "refreshChannelState" },
        { "actor": "b", "type": "refreshChannelState" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "ready", "isJoined": true, "canTransmitNow": true, "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "phase": "ready", "isJoined": true, "canTransmitNow": true, "noInvariantViolations": true }
      }
    },
    {
      "description": "disconnect clears both joined states",
      "actions": [
        { "actor": "a", "type": "disconnect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "isJoined": false, "isTransmitting": false },
        "b": { "selectedHandle": "@avery", "isJoined": false, "isTransmitting": false }
      }
    }
  ]
}
