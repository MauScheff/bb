{
  "name": "fast_relay_idle_network_migration",
  "baseURL": "https://beepbeep.to",
  "participants": {
    "a": { "handle": "@avery", "deviceId": "sim-scenario-avery" },
    "b": { "handle": "@blake", "deviceId": "sim-scenario-blake" }
  },
  "steps": [
    {
      "description": "both Friends open each other",
      "actions": [
        { "actor": "a", "type": "openFriend", "friend": "b" },
        { "actor": "b", "type": "openFriend", "friend": "a" }
      ]
    },
    {
      "description": "Beep reaches recipient",
      "actions": [{ "actor": "a", "type": "connect" }],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "outgoingBeep", "isJoined": false, "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "phase": "incomingBeep", "isJoined": false, "noInvariantViolations": true }
      }
    },
    {
      "description": "recipient joins and sender becomes friendReady",
      "actions": [{ "actor": "b", "type": "connect" }],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "friendReady", "isJoined": false, "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "phase": "waitingForPeer", "isJoined": true, "noInvariantViolations": true }
      }
    },
    {
      "description": "both sides become ready",
      "actions": [{ "actor": "a", "type": "connect" }],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "ready", "isJoined": true, "canTransmitNow": true, "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "phase": "ready", "isJoined": true, "canTransmitNow": true, "noInvariantViolations": true }
      }
    },
    {
      "description": "idle fast relay starts on Wi-Fi",
      "actions": [
        { "actor": "a", "type": "setMediaTransportPath", "pathState": "fast-relay" },
        { "actor": "a", "type": "setNetworkInterface", "networkInterface": "wifi", "reason": "scenario-wifi" }
      ],
      "expectEventually": {
        "a": {
          "selectedHandle": "@blake",
          "phase": "ready",
          "isJoined": true,
          "transportPathState": "fast-relay",
          "localNetworkInterface": "wifi",
          "noInvariantViolations": true
        }
      }
    },
    {
      "description": "idle fast relay survives sender migration to cellular",
      "actions": [
        { "actor": "a", "type": "setNetworkInterface", "networkInterface": "cellular", "reason": "scenario-network-migration" },
        { "actor": "a", "type": "captureDiagnostics" }
      ],
      "expectEventually": {
        "a": {
          "selectedHandle": "@blake",
          "phase": "ready",
          "isJoined": true,
          "transportPathState": "fast-relay",
          "localNetworkInterface": "cellular",
          "noInvariantViolations": true
        }
      }
    }
  ]
}
