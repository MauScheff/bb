{
  "name": "beep_cancel_before_accept",
  "baseURL": "https://beepbeep.to",
  "participants": {
    "a": {
      "handle": "@avery",
      "deviceId": "sim-scenario-avery"
    },
    "b": {
      "handle": "@blake",
      "deviceId": "sim-scenario-blake"
    }
  },
  "steps": [
    {
      "description": "both Friends open each other",
      "actions": [
        { "actor": "a", "type": "openFriend", "friend": "b" },
        { "actor": "b", "type": "openFriend", "friend": "a" }
      ]
    },
    {
      "description": "Beep propagates to recipient",
      "actions": [
        { "actor": "a", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "outgoingBeep", "isJoined": false },
        "b": { "selectedHandle": "@avery", "phase": "incomingBeep", "isJoined": false }
      }
    },
    {
      "description": "sender cancels before recipient accepts",
      "actions": [
        { "actor": "a", "type": "cancelBeep" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "idle", "isJoined": false, "isTransmitting": false },
        "b": { "selectedHandle": "@avery", "phase": "idle", "isJoined": false, "isTransmitting": false }
      }
    }
  ]
}
