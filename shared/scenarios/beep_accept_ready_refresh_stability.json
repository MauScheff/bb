{
  "name": "beep_accept_ready_refresh_stability",
  "baseURL": "https://beepbeep.to",
  "participants": {
    "a": {
      "handle": "@avery",
      "deviceId": "sim-scenario-avery"
    },
    "b": {
      "handle": "@blake",
      "deviceId": "sim-scenario-blake"
    }
  },
  "steps": [
    {
      "description": "both Friends open each other",
      "actions": [
        { "actor": "a", "type": "openFriend", "friend": "b" },
        { "actor": "b", "type": "openFriend", "friend": "a" }
      ]
    },
    {
      "description": "Beep reaches recipient",
      "actions": [
        { "actor": "a", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "outgoingBeep", "isJoined": false, "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "phase": "incomingBeep", "isJoined": false, "noInvariantViolations": true }
      }
    },
    {
      "description": "recipient joins and sender becomes friendReady",
      "actions": [
        { "actor": "b", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "friendReady", "isJoined": false, "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "phase": "waitingForPeer", "isJoined": true, "noInvariantViolations": true }
      }
    },
    {
      "description": "both sides become ready",
      "actions": [
        { "actor": "a", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "ready", "isJoined": true, "canTransmitNow": true, "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "phase": "ready", "isJoined": true, "canTransmitNow": true, "noInvariantViolations": true }
      }
    },
    {
      "description": "refresh and reconciliation keep the ready Conversation stable",
      "actions": [
        { "actor": "a", "type": "refreshContactSummaries" },
        { "actor": "a", "type": "refreshBeeps" },
        { "actor": "a", "type": "refreshChannelState" },
        { "actor": "a", "type": "reconcileSelectedConversation" },
        { "actor": "b", "type": "refreshContactSummaries" },
        { "actor": "b", "type": "refreshBeeps" },
        { "actor": "b", "type": "refreshChannelState" },
        { "actor": "b", "type": "reconcileSelectedConversation" }
      ],
      "expectEventually": {
        "a": {
          "selectedHandle": "@blake",
          "phase": "ready",
          "isJoined": true,
          "canTransmitNow": true,
          "noInvariantViolations": true,
          "backend": {
            "channelStatus": "ready",
            "readiness": "ready",
            "selfJoined": true,
            "peerJoined": true,
            "peerDeviceConnected": true,
            "canTransmit": true
          }
        },
        "b": {
          "selectedHandle": "@avery",
          "phase": "ready",
          "isJoined": true,
          "canTransmitNow": true,
          "noInvariantViolations": true,
          "backend": {
            "channelStatus": "ready",
            "readiness": "ready",
            "selfJoined": true,
            "peerJoined": true,
            "peerDeviceConnected": true,
            "canTransmit": true
          }
        }
      }
    },
    {
      "description": "disconnect clears both joined states",
      "actions": [
        { "actor": "a", "type": "disconnect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "isJoined": false, "isTransmitting": false, "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "isJoined": false, "isTransmitting": false, "noInvariantViolations": true }
      }
    },
    {
      "description": "post-disconnect explicit refresh converges both sides back to idle",
      "actions": [
        { "actor": "a", "type": "wait", "milliseconds": 2500 },
        { "actor": "a", "type": "refreshContactSummaries" },
        { "actor": "a", "type": "refreshBeeps" },
        { "actor": "a", "type": "refreshChannelState" },
        { "actor": "a", "type": "reconcileSelectedConversation" },
        { "actor": "b", "type": "refreshContactSummaries" },
        { "actor": "b", "type": "refreshBeeps" },
        { "actor": "b", "type": "refreshChannelState" },
        { "actor": "b", "type": "reconcileSelectedConversation" }
      ],
      "expectEventually": {
        "a": {
          "selectedHandle": "@blake",
          "phase": "idle",
          "isJoined": false,
          "isTransmitting": false,
          "noInvariantViolations": true,
          "contacts": [
            { "handle": "@blake", "listState": "idle", "isOnline": true }
          ]
        },
        "b": {
          "selectedHandle": "@avery",
          "phase": "idle",
          "isJoined": false,
          "isTransmitting": false,
          "noInvariantViolations": true,
          "contacts": [
            { "handle": "@avery", "listState": "idle", "isOnline": true }
          ]
        }
      }
    }
  ]
}
