{
  "name": "reordered_transmit_signals_refresh_recovery",
  "baseURL": "https://beepbeep.to",
  "requiresLocalBackend": true,
  "participants": {
    "a": {
      "handle": "@avery",
      "deviceId": "sim-scenario-avery"
    },
    "b": {
      "handle": "@blake",
      "deviceId": "sim-scenario-blake"
    }
  },
  "steps": [
    {
      "description": "both Friends open each other",
      "actions": [
        { "actor": "a", "type": "openFriend", "friend": "b" },
        { "actor": "b", "type": "openFriend", "friend": "a" }
      ]
    },
    {
      "description": "Beep reaches recipient",
      "actions": [
        { "actor": "a", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "outgoingBeep", "isJoined": false },
        "b": { "selectedHandle": "@avery", "phase": "incomingBeep", "isJoined": false }
      }
    },
    {
      "description": "recipient joins and sender becomes friendReady",
      "actions": [
        { "actor": "b", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "friendReady", "isJoined": false },
        "b": { "selectedHandle": "@avery", "phase": "waitingForPeer", "isJoined": true }
      }
    },
    {
      "description": "both sides become ready",
      "actions": [
        { "actor": "a", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "ready", "isJoined": true, "canTransmitNow": true },
        "b": { "selectedHandle": "@avery", "phase": "ready", "isJoined": true, "canTransmitNow": true }
      }
    },
    {
      "description": "reordered transmit websocket deliveries are repaired by refresh and reconciliation",
      "actions": [
        { "actor": "b", "type": "reorderNextWebSocketSignals", "count": 2 },
        { "actor": "a", "type": "beginTransmit" },
        { "actor": "a", "type": "endTransmit", "delayMilliseconds": 150 },
        { "actor": "b", "type": "refreshChannelState", "delayMilliseconds": 450 },
        { "actor": "b", "type": "reconcileSelectedConversation", "delayMilliseconds": 500 }
      ],
      "expectEventually": {
        "a": {
          "selectedHandle": "@blake",
          "phase": "ready",
          "isJoined": true,
          "isTransmitting": false,
          "backend": {
            "readiness": "ready",
            "canTransmit": true
          },
          "eventuallyNoInvariant": [
            "selected.hold_to_talk_requires_transmit_capability",
            "transmit.live_projection_after_lease_expiry"
          ]
        },
        "b": {
          "selectedHandle": "@avery",
          "phase": "ready",
          "isJoined": true,
          "contacts": [
            { "handle": "@avery", "listState": "ready", "badgeStatus": "ready" }
          ],
          "backend": {
            "readiness": "ready",
            "canTransmit": true
          },
          "eventuallyNoInvariant": [
            "selected.hold_to_talk_requires_transmit_capability",
            "engine.no_playback_after_transmit_stop",
            "transmit.live_projection_after_lease_expiry"
          ]
        }
      }
    }
  ]
}
