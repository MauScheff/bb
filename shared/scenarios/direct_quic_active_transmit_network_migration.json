{
  "name": "direct_quic_active_transmit_network_migration",
  "baseURL": "https://beepbeep.to",
  "participants": {
    "a": { "handle": "@avery", "deviceId": "sim-scenario-avery" },
    "b": { "handle": "@blake", "deviceId": "sim-scenario-blake" }
  },
  "steps": [
    {
      "description": "both Friends open each other",
      "actions": [
        { "actor": "a", "type": "openFriend", "friend": "b" },
        { "actor": "b", "type": "openFriend", "friend": "a" }
      ]
    },
    {
      "description": "Beep reaches recipient",
      "actions": [{ "actor": "a", "type": "connect" }],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "outgoingBeep", "isJoined": false, "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "phase": "incomingBeep", "isJoined": false, "noInvariantViolations": true }
      }
    },
    {
      "description": "recipient joins and sender becomes friendReady",
      "actions": [{ "actor": "b", "type": "connect" }],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "friendReady", "isJoined": false, "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "phase": "waitingForPeer", "isJoined": true, "noInvariantViolations": true }
      }
    },
    {
      "description": "both sides become ready and Direct QUIC is active",
      "actions": [
        { "actor": "a", "type": "connect" },
        { "actor": "a", "type": "setNetworkInterface", "networkInterface": "wifi", "reason": "scenario-wifi", "delayMilliseconds": 200 },
        { "actor": "a", "type": "activateDirectQuicPath", "delayMilliseconds": 300 }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "ready", "isJoined": true, "canTransmitNow": true, "transportPathState": "direct", "localNetworkInterface": "wifi", "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "phase": "ready", "isJoined": true, "canTransmitNow": true, "noInvariantViolations": true }
      }
    },
    {
      "description": "network migration during active Direct QUIC transmit surfaces explicit fallback instead of stale Direct UI",
      "actions": [
        { "actor": "a", "type": "beginTransmit" },
        { "actor": "a", "type": "setNetworkInterface", "networkInterface": "cellular", "reason": "scenario-active-network-migration", "delayMilliseconds": 150 },
        { "actor": "a", "type": "loseDirectQuicPath", "reason": "scenario-network-migration", "delayMilliseconds": 250 }
      ],
      "expectEventually": {
        "a": {
          "selectedHandle": "@blake",
          "phase": "transmitting",
          "isJoined": true,
          "isTransmitting": true,
          "transportPathState": "fast-relay",
          "localNetworkInterface": "cellular",
          "diagnosticsContains": ["Direct QUIC media path lost"],
          "diagnosticsNotContains": ["direct-quic.active_path_surfaced_as_relay"],
          "noInvariantViolations": true
        },
        "b": { "selectedHandle": "@avery", "phase": "receiving", "isJoined": true, "noInvariantViolations": true }
      }
    }
  ]
}
