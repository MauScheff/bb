{
  "name": "beep_accept_ready_disconnect_receiver",
  "baseURL": "https://beepbeep.to",
  "participants": {
    "a": {
      "handle": "@avery",
      "deviceId": "sim-scenario-avery"
    },
    "b": {
      "handle": "@blake",
      "deviceId": "sim-scenario-blake"
    }
  },
  "steps": [
    {
      "description": "both Friends open each other",
      "actions": [
        { "actor": "a", "type": "openFriend", "friend": "b" },
        { "actor": "b", "type": "openFriend", "friend": "a" }
      ]
    },
    {
      "description": "Beep reaches recipient",
      "actions": [
        { "actor": "a", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "outgoingBeep", "isJoined": false },
        "b": { "selectedHandle": "@avery", "phase": "incomingBeep", "isJoined": false }
      }
    },
    {
      "description": "recipient joins and sender becomes friendReady",
      "actions": [
        { "actor": "b", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "friendReady", "isJoined": false },
        "b": { "selectedHandle": "@avery", "phase": "waitingForPeer", "isJoined": true }
      }
    },
    {
      "description": "both sides become ready",
      "actions": [
        { "actor": "a", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "ready", "isJoined": true, "canTransmitNow": true },
        "b": { "selectedHandle": "@avery", "phase": "ready", "isJoined": true, "canTransmitNow": true }
      }
    },
    {
      "description": "receiver disconnects",
      "actions": [
        { "actor": "b", "type": "disconnect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "isJoined": false, "isTransmitting": false },
        "b": { "selectedHandle": "@avery", "isJoined": false, "isTransmitting": false }
      }
    }
  ]
}
