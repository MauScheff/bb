{
  "name": "fast_relay_lock_unlock_recovery",
  "baseURL": "https://beepbeep.to",
  "participants": {
    "a": { "handle": "@avery", "deviceId": "sim-scenario-avery" },
    "b": { "handle": "@blake", "deviceId": "sim-scenario-blake" }
  },
  "steps": [
    {
      "description": "both Friends open each other",
      "actions": [
        { "actor": "a", "type": "openFriend", "friend": "b" },
        { "actor": "b", "type": "openFriend", "friend": "a" }
      ]
    },
    {
      "description": "Beep reaches recipient",
      "actions": [{ "actor": "a", "type": "connect" }],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "outgoingBeep", "isJoined": false, "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "phase": "incomingBeep", "isJoined": false, "noInvariantViolations": true }
      }
    },
    {
      "description": "recipient joins and sender becomes friendReady",
      "actions": [{ "actor": "b", "type": "connect" }],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "friendReady", "isJoined": false, "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "phase": "waitingForPeer", "isJoined": true, "noInvariantViolations": true }
      }
    },
    {
      "description": "both sides become ready on fast relay",
      "actions": [
        { "actor": "a", "type": "connect" },
        { "actor": "a", "type": "setMediaTransportPath", "pathState": "fast-relay", "delayMilliseconds": 200 }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "ready", "isJoined": true, "canTransmitNow": true, "transportPathState": "fast-relay", "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "phase": "ready", "isJoined": true, "canTransmitNow": true, "noInvariantViolations": true }
      }
    },
    {
      "description": "receiver lock degrades sender to wake-ready",
      "actions": [{ "actor": "b", "type": "lockApp" }],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "wakeReady", "isJoined": true, "canTransmitNow": false, "transportPathState": "fast-relay", "noInvariantViolations": true },
        "b": { "noInvariantViolations": true }
      }
    },
    {
      "description": "receiver unlock plus refresh restores readiness",
      "actions": [
        { "actor": "b", "type": "unlockApp" },
        { "actor": "b", "type": "refreshChannelState" },
        { "actor": "a", "type": "refreshChannelState" },
        { "actor": "a", "type": "reconcileSelectedConversation" },
        { "actor": "b", "type": "reconcileSelectedConversation" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "ready", "isJoined": true, "canTransmitNow": true, "transportPathState": "fast-relay", "noInvariantViolations": true },
        "b": { "selectedHandle": "@avery", "phase": "ready", "isJoined": true, "canTransmitNow": true, "noInvariantViolations": true }
      }
    }
  ]
}
