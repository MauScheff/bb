{
  "schemaVersion": 1,
  "description": "Backend channel contract variants consumed by the iOS client.",
  "contracts": {
    "beepThreadProjection": {
      "path": "beepThreadProjection.kind",
      "variants": ["none", "incoming", "outgoing", "mutual"]
    },
    "membership": {
      "path": "membership.kind",
      "variants": ["absent", "self-only", "peer-only", "both"],
      "requiredByVariant": {
        "peer-only": ["peerDeviceConnected"],
        "both": ["peerDeviceConnected"]
      }
    },
    "conversationStatus": {
      "path": "conversationStatus.kind",
      "variants": [
        "idle",
        "outgoing-beep",
        "incoming-beep",
        "connecting",
        "waiting-for-peer",
        "ready",
        "self-transmitting",
        "peer-transmitting"
      ]
    },
    "readiness": {
      "path": "readiness.kind",
      "variants": [
        "inactive",
        "waiting-for-self",
        "waiting-for-peer",
        "ready",
        "self-transmitting",
        "peer-transmitting"
      ]
    },
    "audioReadiness": {
      "path": "audioReadiness.{self,peer}.kind",
      "variants": ["unknown", "waiting", "wake-capable", "ready"]
    },
    "wakeReadiness": {
      "path": "wakeReadiness.{self,peer}.kind",
      "variants": ["unavailable", "wake-capable"],
      "requiredByVariant": {
        "wake-capable": ["targetDeviceId"]
      }
    }
  },
