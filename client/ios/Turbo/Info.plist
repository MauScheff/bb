<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>BeepBeep</string>
	<key>CFBundleName</key>
	<string>BeepBeep</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>to.beepbeep.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>beepbeep</string>
			</array>
		</dict>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSMicrophoneUsageDescription</key>
	<string>BeepBeep uses the microphone to send push-to-talk audio to the connected contact.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>BeepBeep uses the local network to test direct peer-to-peer push-to-talk connections.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_turbo-preflight._tcp</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>BeepBeep uses the camera to scan QR codes for adding contacts.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSUserActivityTypes</key>
	<array>
		<string>INStartCallIntent</string>
	</array>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>TurboBackendBaseURL</key>
	<string>https://staging.beepbeep.to</string>
	<key>TurboDevUserHandle</key>
	<string>@turbo-ios</string>
	<key>UTImportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeDescription</key>
			<string>PKCS #12 identity</string>
			<key>UTTypeIdentifier</key>
			<string>com.rsa.pkcs-12</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>p12</string>
					<string>pfx</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/pkcs12</string>
					<string>application/x-pkcs12</string>
				</array>
			</dict>
		</dict>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>push-to-talk</string>
	</array>
</dict>
</plist>
